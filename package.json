{
  "name": "sphere",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "docker:db": "docker compose -f packages/api/docker-compose.yml up postgres -d --wait",
    "dev": "npm run docker:db && npm run dev --workspace=@sphere/api & npm run dev --workspace=@sphere/ui",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present"
  }
}
